# Core runtime
HOST=0.0.0.0
PORT=8000
AGENT_PORT=8081
APP_DATA_DIR=/app/data
APP_CONFIG_FILE=/app/data/config.json
KB_DATA_DIR=/app/data/kb
APP_BASE_URL=https://backend.example.com

# LiveKit
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxxxxx
LIVEKIT_API_SECRET=your_livekit_api_secret_here
SIP_TRUNK_ID=ST_xxxxxxxxxxxxxxxx

# Gemini / Google
GOOGLE_API_KEY=your_google_api_key
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
GEMINI_LIVE_VOICE=Puck
GEMINI_LIVE_TEMPERATURE=0.8
GEMINI_LIVE_LANGUAGE=
GEMINI_LIVE_PREFLIGHT_ENABLED=false
GEMINI_LIVE_PREFLIGHT_TIMEOUT=6
GEMINI_LIVE_CONNECT_TIMEOUT=20
GEMINI_LIVE_CONNECT_RETRIES=2
GEMINI_TTS_MODEL=gemini-3.1-flash-tts-preview
LANG_PRESET=multilingual

# Agent behavior
FIRST_LINE=Namaste! This is Aryan from SPX AI - we help businesses automate with AI. Hmm, may I ask what kind of business you run?
AGENT_INSTRUCTIONS=
MAX_TURNS=25
USER_AWAY_TIMEOUT=15
SESSION_CLOSE_TRANSCRIPT_TIMEOUT=2
DEFAULT_TRANSFER_NUMBER=+91XXXXXXXXXX
VOBIZ_SIP_DOMAIN=your_sip_domain.sip.vobiz.ai

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here
SUPABASE_S3_ACCESS_KEY=
SUPABASE_S3_SECRET_KEY=
SUPABASE_S3_ENDPOINT=
SUPABASE_S3_REGION=ap-south-1

# Telegram notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Knowledge base / LeadRat
KB_ENABLED=true
KB_BACKEND=local_faiss
KB_TOP_K=4
KB_INVENTORY_TOP_K=3
KB_SIMILARITY_THRESHOLD=0.18
KB_CONTEXT_CHAR_BUDGET=2800
KB_LIVE_TIMEOUT_MS=150
KB_LIVE_CONTEXT_CHAR_BUDGET=900
KB_CACHE_TTL_SECONDS=45
KB_CHUNK_SIZE=400
KB_CHUNK_OVERLAP=60
KB_WORKER_POLL_SECONDS=20
KB_EMBEDDING_PROVIDER=local
KB_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
KB_EMBEDDING_FALLBACK_PROVIDER=gemini
KB_EMBEDDING_FALLBACK_MODEL=gemini-embedding-001
KB_INDEX_KIND=flat_ip
KB_RERANK_ENABLED=false
LEADRAT_ENABLED=false
LEADRAT_TENANT=
LEADRAT_API_KEY=
LEADRAT_SECRET_KEY=
LEADRAT_SYNC_INTERVAL_MINUTES=5
LEADRAT_BASE_URL=https://connect.leadrat.com
